FROM python:3.12-slim

WORKDIR /app

# Keep output visible
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app:/app/src

# Copy package sources and tests
COPY pyproject.toml README.md ./
COPY src/ ./src/
COPY tests/ ./tests/
COPY scripts/ ./scripts/
COPY examples/ ./examples/

# Install packaging/build tools and dev dependencies, then run tests
RUN pip install --upgrade pip setuptools wheel
RUN pip install --no-cache-dir "pydantic==2.9.2" "pydantic-core"
RUN pip install --no-cache-dir ".[dev]"

# Ensure the wait_and_test script is LF and executable inside the image
RUN apt-get update && apt-get install -y dos2unix bash && \
	dos2unix ./scripts/wait_and_test.sh && \
	chmod +x ./scripts/wait_and_test.sh && \
	apt-get clean && rm -rf /var/lib/apt/lists/*

CMD ["pytest", "-v"]
